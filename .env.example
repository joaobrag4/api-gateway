# Variáveis de ambiente — NUNCA commitar o .env real no GitHub!
# Copie este arquivo para .env e preencha os valores

# ─── Segurança ────────────────────────────────────────────────────────────────
# Chave secreta do gateway — gere uma string aleatória forte
# Sugestão: openssl rand -hex 32
GATEWAY_API_KEY=sua-chave-secreta-aqui

# ─── Servidor ─────────────────────────────────────────────────────────────────
# O Railway define PORT automaticamente — não precisa alterar
PORT=3000
